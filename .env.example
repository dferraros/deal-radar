# Deal Radar — Environment Variables
# Copy to .env and fill in your values. Never commit .env.

# PostgreSQL connection string (Railway provides this automatically via the Postgres addon)
DATABASE_URL=postgresql://user:password@localhost:5432/deal_radar

# Data source API keys
TAVILY_API_KEY=your_tavily_api_key_here
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# AI extraction (at least one required)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
